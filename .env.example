# HeatShield AI — environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Every variable below is optional for DEMO MODE — the app runs with zero keys.

# --- Core ---
# SQLite (default, zero-setup) or PostgreSQL+PostGIS for production.
DATABASE_URL=sqlite:///./heatshield.db
# DATABASE_URL=postgresql+psycopg://heatshield:heatshield@localhost:5432/heatshield
APP_ENV=development
FRONTEND_URL=http://localhost:5173

# --- Weather provider ---
# "open-meteo" = live, NO API KEY REQUIRED (default). "openweathermap" = needs key below.
WEATHER_PROVIDER=open-meteo
WEATHER_API_KEY=

# --- Satellite provider ---
# "none" (demo), "gee" (Google Earth Engine), or "copernicus".
SATELLITE_PROVIDER=none
GEE_PROJECT_ID=
GEE_SERVICE_ACCOUNT_EMAIL=
GEE_CREDENTIALS_PATH=
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# --- Map tiles (frontend) ---
# Optional. A keyless dark basemap is used if this is blank.
# If set, expose it to the frontend build as VITE_MAP_PROVIDER_KEY too.
MAP_PROVIDER_KEY=

# --- Cache (optional) ---
# Redis URL for multi-worker deployments. In-process cache used if blank.
CACHE_URL=
